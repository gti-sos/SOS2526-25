              "listen": "test",
              "script": {
                "exec": [
                  "\r",
                  "pm.test(\"Los objetos tienen los campos correctos y tambien el tipo de dato\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    if (jsonData.length > 0) {\r",
                  "        // Comprobamos que el primer elemento tiene los campos obligatorios\r",
                  "        pm.expect(jsonData[0]).to.have.property(\"country\");\r",
                  "        pm.expect(jsonData[0]).to.have.property(\"year\");\r",
                  "        pm.expect(jsonData[0]).to.have.property(\"co2_emission\");\r",
                  "        \r",
                  "        // Comprobar también el tipo de dato\r",
                  "        pm.expect(jsonData[0].year).to.be.a(\"number\");\r",
                  "        pm.expect(jsonData[0].country).to.be.a(\"string\");\r",
                  "    }\r",
                  "});"
