    {
      "name": "Get specific data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status es 200 OK\", () => pm.response.to.have.status(200));",
              "pm.test(\"Devuelve un objeto JSON válido (no un array)\", () => {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(Array.isArray(jsonData)).to.be.false;",
              "    pm.expect(typeof jsonData).to.eql(\"object\");",
              "});",
              "pm.test(\"Los campos devueltos coinciden exactamente\", () => {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.country).to.eql(\"Spain\");",
              "    pm.expect(jsonData.year).to.eql(2025);",
              "    pm.expect(jsonData.total_liter).to.eql(105.2);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
